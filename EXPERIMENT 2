#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main()
{
    int sourceFile, destFile;
    char buffer[100];
    int bytesRead;

    char sourceName[50], destName[50];

    printf("Enter source file name: ");
    scanf("%s", sourceName);

    printf("Enter destination file name: ");
    scanf("%s", destName);

    sourceFile = open(sourceName, O_RDONLY);

    if (sourceFile < 0)
    {
        printf("Error: Source file not found!\n");
        return 1;
    }

    destFile = open(destName, O_CREAT | O_WRONLY | O_TRUNC, 0644);

    if (destFile < 0)
    {
        printf("Error: Destination file cannot be created!\n");
        close(sourceFile);
        return 1;
    }

    while ((bytesRead = read(sourceFile, buffer, sizeof(buffer))) > 0)
    {
        write(destFile, buffer, bytesRead);
    }

    printf("File copied successfully!\n");

    close(sourceFile);
    close(destFile);

    return 0;
}
