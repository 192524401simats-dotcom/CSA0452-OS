#include <stdio.h>

struct emp {
    int id;
    char name[20];
};

int main() {
    FILE *fp;
    struct emp e;
    int i, n, pos;

    fp = fopen("emp.dat", "wb+");

    printf("Enter number of employees: ");
    scanf("%d", &n);

    // Store data
    for(i = 0; i < n; i++) {
        printf("Enter ID and Name: ");
        scanf("%d %s", &e.id, e.name);
        fwrite(&e, sizeof(e), 1, fp);
    }

    // Access data
    printf("Enter record number: ");
    scanf("%d", &pos);

    fseek(fp, (pos - 1) * sizeof(e), SEEK_SET);
    fread(&e, sizeof(e), 1, fp);

    printf("Employee: %d %s", e.id, e.name);

    fclose(fp);
    return 0;
}

INPUT:
Enter number of employees: 2
Enter ID and Name: 101 Ram
Enter ID and Name: 102 Ravi
Enter record number: 2

OUTPUT:
Employee: 102 Ravi
