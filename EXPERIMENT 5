#include <stdio.h>

int main() {
    int n, bt[10], pr[10], p[10], wt[10], tat[10], i, j, t, tw=0, tt=0;

    printf("Enter no of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++){
        p[i]=i+1;
        printf("Enter BT and Priority for P%d: ",p[i]);
        scanf("%d%d",&bt[i],&pr[i]);
    }

    for(i=0;i<n;i++)
        for(j=i+1;j<n;j++)
            if(pr[i]>pr[j]){
                t=pr[i]; pr[i]=pr[j]; pr[j]=t;
                t=bt[i]; bt[i]=bt[j]; bt[j]=t;
                t=p[i]; p[i]=p[j]; p[j]=t;
            }

    wt[0]=0;
    for(i=1;i<n;i++) wt[i]=wt[i-1]+bt[i-1];

    printf("\nP\tBT\tPR\tWT\tTAT\n");
    for(i=0;i<n;i++){
        tat[i]=wt[i]+bt[i];
        tw+=wt[i]; tt+=tat[i];
        printf("P%d\t%d\t%d\t%d\t%d\n",p[i],bt[i],pr[i],wt[i],tat[i]);
    }

    printf("\nAvg WT=%.2f", (float)tw/n);
    printf("\nAvg TAT=%.2f\n", (float)tt/n);

    return 0;
}

