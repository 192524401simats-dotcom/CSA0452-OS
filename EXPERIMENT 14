#include <stdio.h>
#include <string.h>

int main() {
    int n, i;
    char files[10][20], search[20];

    printf("Enter number of files: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        scanf("%s", files[i]);
    }

    printf("Enter file to search: ");
    scanf("%s", search);

    for(i = 0; i < n; i++) {
        if(strcmp(files[i], search) == 0) {
            printf("File found");
            return 0;
        }
    }

    printf("File not found");
    return 0;
}

